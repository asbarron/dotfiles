#!/usr/bin/env sh
# Yabai + YMSP (yabai-master-stack-plugin) config
# Restart yabai after changes: yabai --restart-service (or sudo yabai --restart-service)

# bsp = binary space partition (default); ymsp overrides with master-stack via signals below
yabai -m config layout bsp
yabai -m config window_placement first_child
yabai -m config mouse_modifier fn

# Apps that yabai should not manage (float / ignore) 
yabai -m rule --add app='System Settings' manage=off
yabai -m rule --add app='Notion Calendar' manage=off

# Window appearance 
yabai -m config window_shadow float
yabai -m config window_opacity on
# Focus indicator (alt+j / alt+k): focused = full opacity, unfocused = dimmed. Works without scripting addition.
yabai -m config active_window_opacity 1.0
yabai -m config normal_window_opacity 0.65
yabai -m config menubar_opacity 0.5

# Optional: colored borders (only work if scripting addition is loaded: sudo yabai --load-sa)
# yabai -m config window_border on
# yabai -m config window_border_width 4
# yabai -m config active_window_border_color 0xff8be9fd
# yabai -m config normal_window_border_color 0xff44475a

# --- YMSP: master-stack layout (dwm-style) ---
# When a new window is created or an app launches, ymsp repositions it into master/stack
if [ -x "$HOME/.bun/bin/ymsp" ]; then
  yabai -m signal --add event=window_created action="$HOME/.bun/bin/ymsp window-created"
  yabai -m signal --add event=application_launched action="$HOME/.bun/bin/ymsp window-created"

  # Apply master-stack layout when yabai starts (use "on-yabai-start", not startup)
  "$HOME/.bun/bin/ymsp" on-yabai-start
else
  echo "ymsp not found at $HOME/.bun/bin/ymsp; skipping ymsp hooks"
fi

echo "yabai profile loaded"
